		{
			"name": "📦 Productos",
			"item": [
				{
					"name": "Crear Producto",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"name\": \"Laptop Dell Inspiron 15\",\n  \"description\": \"Laptop profesional Intel i7, 16GB RAM, 512GB SSD\",\n  \"price\": 1200.00,\n  \"stock\": 10,\n  \"category\": \"Electrónica\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/products",
							"host": ["{{baseUrl}}"],
							"path": ["api", "products"]
						},
						"description": "Crea un nuevo producto en el catálogo.\n\nValidaciones:\n- Precio > 0\n- Stock >= 0"
					},
					"response": []
				},
				{
					"name": "Listar Todos los Productos",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/products",
							"host": ["{{baseUrl}}"],
							"path": ["api", "products"]
						},
						"description": "Obtiene el catálogo completo de productos."
					},
					"response": []
				},
				{
					"name": "Obtener Producto por ID",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/products/{{productId}}",
							"host": ["{{baseUrl}}"],
							"path": ["api", "products", "{{productId}}"]
						},
						"description": "Obtiene los detalles de un producto específico."
					},
					"response": []
				},
				{
					"name": "Filtrar por Categoría",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/products/category/Electrónica",
							"host": ["{{baseUrl}}"],
							"path": ["api", "products", "category", "Electrónica"]
						},
						"description": "Filtra productos por categoría.\n\nCategorías de ejemplo:\n- Electrónica\n- Accesorios\n- Audio"
					},
					"response": []
				},
				{
					"name": "Actualizar Stock",
					"request": {
						"method": "PUT",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/products/{{productId}}/stock?stock=100",
							"host": ["{{baseUrl}}"],
							"path": ["api", "products", "{{productId}}", "stock"],
							"query": [
								{
									"key": "stock",
									"value": "100",
									"description": "Nueva cantidad en inventario"
								}
							]
						},
						"description": "Actualiza el stock de un producto.\n\nValidación: stock >= 0"
					},
					"response": []
				},
				{
					"name": "Actualizar Precio",
					"request": {
						"method": "PUT",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/products/{{productId}}/price?price=999.99",
							"host": ["{{baseUrl}}"],
							"path": ["api", "products", "{{productId}}", "price"],
							"query": [
								{
									"key": "price",
									"value": "999.99",
									"description": "Nuevo precio"
								}
							]
						},
						"description": "Actualiza el precio de un producto.\n\nValidación: precio > 0"
					},
					"response": []
				}
			],
			"description": "Endpoints para gestión del catálogo de productos e inventario."
